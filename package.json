{
  "name": "n8n-nodes-actual",
  "version": "0.1.0",
  "description": "Custom n8n node to post transactions to Actual Budget via @actual-app/api",
  "keywords": [
    "n8n-nodes",
    "n8n",
    "actual",
    "budget"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "main": "dist/src/server.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "nodes": [
      "dist/nodes/Actual/Actual.node.js"
    ],
    "credentials": [
      "dist/credentials/ActualApi.credentials.js"
    ]
  },
  "dependencies": {
     "@actual-app/api": "25.10.0",
     "express": "^4.19.2"
   },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2",
    "n8n-workflow": "^1.53.0",
    "typescript": "^5.4.0"
  }
}
